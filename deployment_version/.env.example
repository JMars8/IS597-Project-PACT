# Copy this file to .env and fill in your values.
# On Railway, set these as environment variables in the dashboard — do NOT commit .env.

# Required: Groq API key for local LLM synthesis and health detection
# Get a free key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: OpenAI API key — users can also enter this in the UI sidebar
# If set here it is used as a fallback when the user has not entered one
GPT_API_KEY=your_openai_api_key_here

# Optional: override the Groq model (default: llama-3.1-8b-instant)
# GROQ_MODEL=llama-3.1-8b-instant
